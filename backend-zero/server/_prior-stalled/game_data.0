    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Hacker") { return "You may expend your special armor to resist the consequences of hacking, or to push yourself when hacking or gathering info electronically." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Fixed") { return "You may expend your special armor to resist a consequence from machines breaking or being damaged, or to push yourself when repairing or building a machine." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Mechanic's Heart") { return "When you speak from your heart, your words can reach even the most hardened criminal, and you gain potency." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Overclock") { return "When you spend a gambit on a rig roll to repair or upgrade, treat the system you worked on as 1 quality higher for the remainder of the job." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Analyst") { return "When you hack a system, you may also ask a question about the owner or location of the system as though you had rolled a 6 on gather info. When you resist the consequences of hacking, roll +1d." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mechanic") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Wrecking Crew") { return "Your strength and ferocity are infamous. When striking in melee, you gain +1d. Whenever you spend a gambit in combat, you also gain +1 effect on that action." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Backup") { return "An ally's push costs 1 stress (not 2) on any action you set up or assist." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Battleborn") { return "You may expend your special armor to reduce harm from an attack in combat, or to push yourself during a fight." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Bodyguard") { return "When you protect a crewmate, resist with +1d. When you take harm, clear 1 stress." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Flesh Wound") { return "If you're wounded at the beginning of downtime, mark +3 segments on your healing clock. When you push yourself to ignore wound penalties, it takes only 1 stress (not 2)." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Predator") { return "Take +1d to rolls against weakened or vulnerable targets.Whenever you gather information on a weakness or vulnerability, the worst you can get is a 4/5 result." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Ready For Anything") { return "When being ambushed, you gain potency to all actions during a flashback, and your first flashback costs 0 stress." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Scary") { return "You have an air of menace and danger obvious to even the most unobservant. You gain potency when trying to intimidate someone. If done immediately after a show of force, also take +1d." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Muscle") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Kinetics") { return "You can push yourself to do one of the following: use The Way to throw a table-sized object with dangerous force—propel yourself briefly with superhuman speed." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Psy-Blade") { return "You can focus Way energy into your melee weapon. While charged, the weapon can cut through non-shielded materials with ease, and you gain potency on your melee attacks." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Center") { return "You gain Meditation as a vice. When you indulge this vice, clear +1 stress and add Dark Visions as a possible overindulgence." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Way Shield") { return "You can block blaster bolts with The Way (resist with resolve). If you resist a blaster attack, you may spend 1 stress to redirect fire and make an attack of your own with it." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Warded") { return "You may expend your special armor to resist the consequences of a Way attack or artifact use, or push yourself when using mystic powers." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Psy-Dancing") { return "You may push yourself to cloud a target's mind and sway them in the face of contradictory evidence. Spend 1 stress for each additional feature: they have only vague memories of the event and/or it works on a small group." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Visions") { return "Spend 1 stress to remotely view a distant place or person tied to you in some intimate way. Spend 1 stress for each extra feature: it lasts for a minute rather than a moment—your target can also see and hear you—you may see something only familiar to you, not intimate." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Sundering") { return "You may push yourself to attune to The Way and twist it, causing psychic harm to anyone in the area vulnerable to your assault. You may spend 1 stress for each additional feature: it damages instead of stuns—you and anyone you choose get +2d to resist the effects." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Mystic") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Keen Eye") { return "You have sharp eyes and notice small details many might overlook. Gain +1d when firing ship guns or making trick shots." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Side Job") { return "You may spend a downtime activity in port doing odd jobs. Gain 1 cred. If there are rumors floating about, the GM will tell you of them." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Exceed Specs") { return "While onboard a ship, you may damage a ship system you have access to in order to gain +1d or +1 effect to a roll." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Leaf On The Wind") { return "When you push yourself, you may spend +1 stress (3 stress total) to gain both +1 effect and +1d instead of one or the other." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Hedonist") { return "When you indulge your vice, you may adjust the dice outcome by +/-2. An ally who joins you may do the same." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Commander") { return "Whenever you lead a group action, gain +1 scale (for example, a small group counts as a medium group). If you lead a group action in combat, you may count multiple 6s from different rolls as a critical." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Traveler") { return "You're comfortable around unusual cultures and xenos. You gain potency when attempting to consort with or sway them." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Punch It!") { return "When you spend a gambit on a desperate roll, it counts as risky instead." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Pilot") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Never Tell Me The Odds") { return "You generate gambits on desperate rolls. You may also generate gambits even if you spent a gambit." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "I Know A Guy") { return "When you first dock at a port after being away, pick one and ask the GM about a job: it's not deadly—it pays well enough—it's not a rush job—it comes from a faction you trust—it targets an enemy you have. You may spend 1 cred per additional feature." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Tenacious") { return "Penalties from harm are one level less severe (though level 4 harm is still fatal)." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "When The Chips Are Down") { return "You gain a second use of special armor between each downtime." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Devil's Own Luck") { return "You may expend your special armor to resist the consequences of blaster fire, or to push yourself when talking your way out of (or running from) trouble." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Daredevil") { return "When you make a desperate roll, you may take +1d. If you do so, do not mark xp in that action's attribute." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Shoot First") { return "When you attack from hiding or spring a trap, take +1d. When there's a question about who acts first, the answer is you (two characters with Shoot First act simultaneously)." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Ask Questions Later") { return "When you consort to gather info, you gain +1 effect and can in addition ask: Who might this benefit?" }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Scoundrel") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Favors Owed") { return "During downtime, you get +1d when you acquire assets or lay low. Any time you gather info, take +1d." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Player") { return "You always know when someone is lying to you." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Infiltrator") { return "You are not affected by quality or Tier when you bypass security measures." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Subterfuge") { return "You may expend your special armor to resist a consequence of persuasion or suspicion. When you resist with insight, gain +1d." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Heart to Heart") { return "When you provide meaningful insight or heartfelt advice that a crewmate follows, you both clear 1 stress." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Old Friends") { return "Whenever you land in a new location, write down a friend you know there (see Influential Friends)." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Disarming") { return "Whenever you use a gambit while speaking, hostilities and danger also pause while you speak." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Purpose") { return "You may expend your special armor to push yourself when outclassed by your opposition, or when under the effects of wounds. When you resist with resolve, gain +1d." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Speaker") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Physicker") { return "You may study a malady, wounds, or corpse, and gather info from a crime scene. Also, your crew gets +1d to recovery rolls." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Patch") { return "You may doctor someone during a job to allow them to ignore the effects of a harm penalty." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Welcome Anywhere") { return "While wearing your medic garb, you are welcome even in dangerous places. Gain +1d to consort and sway when offering to tend to anyone in need." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Under Pressure") { return "Add a gambit to the pool whenever you or a crew member suffers level 2 or greater harm." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Combat Medic") { return "You may expend your special armor to resist any consequence while tending to a patient. When you doctor someone in combat, clear 1 stress." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Moral Compass") { return "When you do the right thing at cost to yourself, mark xp (any category)." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Dr. Strange") { return "Your research and fields of study are fringe, esoteric, and focus on the mystical. You may always handle Precursor artifacts safely. When you study an artifact or doctor a strange substance, you may ask one: what could this do?—why could this be dangerous?" }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Book Learning") { return "You speak a multitude of languages and are broadly educated. Gain +1d when using study during a downtime activity." }
    if std.mem.eql(stem, "scum-and-villainy") && std.mem.eql(playbook, "Stitch") && std.mem.eql(name, "Veteran") { return "Choose a special ability from another source." }
    return ""
}
