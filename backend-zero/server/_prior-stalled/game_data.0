pub fn has_crew_type(name: Span<u8>) -> Bool {
    if std.mem.eql(name, "Assassins") { return true }
    if std.mem.eql(name, "Bravos") { return true }
    if std.mem.eql(name, "Cultists") { return true }
    if std.mem.eql(name, "Hawkers") { return true }
    if std.mem.eql(name, "Shadows") { return true }
    if std.mem.eql(name, "Smugglers") { return true }
    return false
}

pub fn is_blades(stem: Span<u8>) -> Bool { return std.mem.eql(stem, "blades-in-the-dark") }
pub fn is_scum(stem: Span<u8>) -> Bool { return std.mem.eql(stem, "scum-and-villainy") }
pub fn known_stem(stem: Span<u8>) -> Bool { return is_blades(stem) || is_scum(stem) }
pub fn game_name(stem: Span<u8>) -> Span<u8> {
    if is_blades(stem) { return blades_game_name() }
    if is_scum(stem) { return scum_game_name() }
    return ""
}
pub fn game_language(stem: Span<u8>) -> Span<u8> {
    if is_blades(stem) { return blades_language() }
    if is_scum(stem) { return scum_language() }
    return ""
}
pub fn action_point_maximum(stem: Span<u8>) -> u32 {
    if is_blades(stem) { return blades_action_max() }
    if is_scum(stem) { return scum_action_max() }
    return 4
}
pub fn recovery_clock_size(stem: Span<u8>) -> u32 {
    if is_blades(stem) { return blades_recovery() }
    if is_scum(stem) { return scum_recovery() }
    return 4
}
pub fn has_playbook(stem: Span<u8>, playbook: Span<u8>) -> Bool {
    if is_blades(stem) { return blades_has_playbook(playbook) }
    if is_scum(stem) { return scum_has_playbook(playbook) }
    return false
}
pub fn default_rating(stem: Span<u8>, playbook: Span<u8>, action: Span<u8>) -> u32 {
    if is_blades(stem) { return blades_default_rating(playbook, action) }
    if is_scum(stem) { return scum_default_rating(playbook, action) }
    return 0
}
pub fn attr_count(stem: Span<u8>) -> u32 {
    if is_blades(stem) { return blades_attr_count() }
    if is_scum(stem) { return scum_attr_count() }
    return 0
}
pub fn attr_name(stem: Span<u8>, i: u32) -> Span<u8> {
    if is_blades(stem) { return blades_attr_name(i) }
    if is_scum(stem) { return scum_attr_name(i) }
    return ""
}
pub fn action_count(stem: Span<u8>, ai: u32) -> u32 {
    if is_blades(stem) { return blades_action_count(ai) }
    if is_scum(stem) { return scum_action_count(ai) }
    return 0
}
pub fn action_name(stem: Span<u8>, ai: u32, aj: u32) -> Span<u8> {
    if is_blades(stem) { return blades_action_name(ai, aj) }
    if is_scum(stem) { return scum_action_name(ai, aj) }
    return ""
}
