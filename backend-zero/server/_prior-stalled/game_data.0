    if std.mem.eql(playbook, "Slide") && std.mem.eql(action, "Sway") { return 2 }
    if std.mem.eql(playbook, "Slide") && std.mem.eql(action, "Consort") { return 1 }
    if std.mem.eql(playbook, "Spider") && std.mem.eql(action, "Consort") { return 2 }
