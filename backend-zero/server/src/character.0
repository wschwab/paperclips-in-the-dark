fn write_fatal_array(v: MutSpan<u8>, c: ref<Character>) -> Bool {
    if !jb_begin_arr(v) {
        return false
    }
    var i: u32 = 0
    while i < c.fatal_count {
        if i > 0 { if !jb_comma(v, true) { return false } }
        if !jb_escaped_string(v, fatal_view(c, i as usize)) {
            return false
        }
        i = i + 1
    }
    return jb_end_arr(v)
}

fn write_gear_array(v: MutSpan<u8>, c: ref<Character>) -> Bool {
    if !jb_begin_arr(v) {
        return false
    }
    var i: u32 = 0
    while i < c.loadout_count {
        if i > 0 {
            if !jb_comma(v, true) {
                return false
            }
        }
        if !jb_begin_obj(v) {
            return false
        }
        if !jb_string_field(v, false, "name", loadout_view(c, i as usize)) {
            return false
        }
        if !jb_u32_field(v, true, "bulk", c.loadout_bulk[i as usize]) {
            return false
        }
        if !jb_end_obj(v) {
            return false
        }
        i = i + 1
    }
    return jb_end_arr(v)
}
