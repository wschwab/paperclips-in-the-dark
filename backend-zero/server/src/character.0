    if !jb_begin_arr(v) {
        return false
    }
    var i: u32 = 0
    while i < c.severe_count {
        if i > 0 { if !jb_comma(v, true) { return false } }
        if !jb_escaped_string(v, severe_view(c, i as usize)) {
