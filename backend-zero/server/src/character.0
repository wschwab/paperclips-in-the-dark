    if !jb_begin_arr(v) {
        return false
    }
    var i: u32 = 0
    while i < c.moderate_count {
        if i > 0 { if !jb_comma(v, true) { return false } }
        if !jb_escaped_string(v, moderate_view(c, i as usize)) {
            return false
        }
        i = i + 1
    }
    return jb_end_arr(v)
}

